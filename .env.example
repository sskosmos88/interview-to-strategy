# Pick one provider and fill in the corresponding section.
# If nothing is configured, the tool falls back to local rule-based parsing.

# --- Anthropic Claude (recommended quality) ---
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- Perplexity (OpenAI-compatible API) ---
PERPLEXITY_API_KEY=pplx-your-key-here
PERPLEXITY_MODEL=llama-3-sonar-large-32k-online

# --- Ollama (local, free, requires running Ollama server) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
